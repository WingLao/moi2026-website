{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npm run prisma:deploy && npm run import:problems && next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:init": "npm run prisma:generate && npx prisma migrate dev --name init && npm run seed && npm run import:problems",
    "db:bootstrap": "npm run prisma:deploy && npm run seed && npm run import:problems",
    "seed": "tsx scripts/seed.ts",
    "sync:user-names": "tsx scripts/sync-user-names.ts",
    "generate:statements": "python3 scripts/generate-problem-statements.py",
    "import:problems": "tsx scripts/import-problems.ts",
    "audit:data": "tsx scripts/data-audit.ts",
    "worker": "tsx scripts/judge-worker.ts"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.10.1",
    "next": "16.2.0",
    "next-auth": "^4.24.13",
    "prisma": "^6.16.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "typescript": "^5"
  }
}
